<mvc:View
    controllerName="project1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:u="sap.ui.unified"
    xmlns="sap.m">
    <Page id="page" showHeader="false">
        <content>

            <HBox id="_IDGenHeaderBar" class="appHeaderBar" justifyContent="SpaceBetween" alignItems="Center">
                <Title id="_IDGenAppTitle" text="Material Duplicate Check" class="appHeaderTitle"/>
                <Image
                    id="_IDGenLogo"
                    src="https://argaamplus.s3.amazonaws.com/06cc8cc7-5629-4cf4-8ac1-636c417df117.png"
                    height="42px"
                    class="appLogo"/>
            </HBox>

            <VBox id="_IDGenVBox">

                <HBox id="_IDGenActionCard" class="actionCard" justifyContent="SpaceBetween" alignItems="Center">
                    <HBox id="_IDGenUploadGroup" alignItems="Center">
                        <Button
                            id="btnUpload"
                            text="Upload Excel"
                            icon="sap-icon://upload"
                            type="Emphasized"
                            class="actionButton sapUiTinyMarginEnd"
                            press="onUploadPress"/>
                        <HBox id="_IDGenFileNameBox" alignItems="Center" visible="{= ${uploadModel>/fileName} !== ''}">
                            <Text
                                id="_IDGenFileNameText"
                                text="{uploadModel>/fileName}"
                                class="sapUiTinyMarginBegin sapUiTinyMarginEnd"/>
                            <Button
                                id="btnRemoveFile"
                                icon="sap-icon://decline"
                                type="Transparent"
                                press="onRemoveFile"
                                tooltip="Remove file"/>
                        </HBox>
                        <u:FileUploader
                            id="excelUploader"
                            name="excelFile"
                            change="onFileChange"
                            fileType="xlsx,xls"
                            class="hiddenUploader"/>
                    </HBox>
                    <Button
                        id="btnCheckDuplicates"
                        text="Check for Duplicates"
                        icon="sap-icon://duplicate"
                        type="Default"
                        class="actionButton"
                        enabled="{= ${uploadModel>/rows}.length > 0}"
                        press="onCheckDuplicates"/>
                    <Button
                        id="btnDownload"
                        text="Download"
                        icon="sap-icon://download"
                        type="Default"
                        class="actionButton"
                        enabled="{= ${uploadModel>/rows}.length > 0}"
                        press="onDownloadPress"/>
                </HBox>

                <VBox id="_IDGenTableWrapper" class="sapUiMediumMarginBeginEnd">

                    <Table
                        id="previewTable"
                        items="{uploadModel>/rows}"
                        visible="{= ${uploadModel>/rows}.length > 0 &amp;&amp; ${resultModel>/results}.length === 0}"
                        class="sapUiSmallMarginTop">
                        <headerToolbar>
                            <Toolbar id="_IDGenToolbar">
                                <Title id="_IDGenTitle" text="Uploaded Records ({uploadModel>/rows/length})"/>
                            </Toolbar>
                        </headerToolbar>
                        <columns>
                            <Column id="colRowNoPrev" hAlign="Center"><Text id="_IDGenTextRowNoPrev" text="Row No"/></Column>
                            <Column id="colStatusPrev" hAlign="Center"><Text id="_IDGenTextStatusPrev" text="Status"/></Column>
                            <Column id="colShortTextPrev"><Text id="_IDGenTextShortTextPrev" text="Short Text"/></Column>
                            <Column id="colMpnPrev"><Text id="_IDGenTextMpnPrev" text="Manufacturer Part Number"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem id="_IDGenColumnListItem1">
                                <cells>
                                    <Text id="_IDGenTextRowNoVal" text="{uploadModel>rowNo}"/>
                                    <ObjectStatus id="_IDGenObjStatusPrev" text="{uploadModel>status}" state="None"/>
                                    <Text id="_IDGenTextShortTextVal" text="{uploadModel>shortText}"/>
                                    <Text id="_IDGenTextMpnVal" text="{uploadModel>mpn}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                    <Table
                        id="resultsTable"
                        items="{resultModel>/results}"
                        visible="{= ${resultModel>/results}.length > 0}"
                        class="sapUiSmallMarginTop">
                        <headerToolbar>
                            <Toolbar id="_IDGenToolbar2">
                                <Title id="_IDGenTitle2" text="Excel Upload vs TAM Table ({resultModel>/results/length})"/>
                            </Toolbar>
                        </headerToolbar>
                        <columns>
    <Column id="colCheckbox" hAlign="Center" width="4rem"><Text id="_IDGenTextCb" text=""/></Column>
    <Column id="colRowNo" hAlign="Center"><Text id="_IDGenTextRowNo" text="Row No"/></Column>
    <Column id="colMatDesc"><Text id="_IDGenTextMatDesc" text="Short Text"/></Column>
    <Column id="colMpn"><Text id="_IDGenTextMpn" text="MPN"/></Column>
    <Column id="colStatus" hAlign="Center"><Text id="_IDGenTextStatus" text="Status"/></Column>
    <Column id="colTamNo"><Text id="_IDGenTextTamNo" text="Material No"/></Column>
    <Column id="colTamDesc"><Text id="_IDGenTextTamDesc" text="Material Desc"/></Column>
    <Column id="colTamLongDesc"><Text id="_IDGenTextTamLongDesc" text="Long Description"/></Column>
</columns>
<items>
    <ColumnListItem id="_IDGenResultItem">
        <cells>
            <CheckBox id="_IDGenCheckBox" selected="{resultModel>selected}" visible="{resultModel>showCheckbox}"/>
            <Text id="_IDGenTextRowVal" text="{resultModel>rowNo}"/>
            <Text id="_IDGenTextDescVal" text="{resultModel>materialDesc}"/>
            <Text id="_IDGenTextMpnVal1" text="{resultModel>mpn}"/>
            <ObjectStatus
                id="_IDGenObjStatus"
                text="{resultModel>status}"
                state="{= ${resultModel>status} === 'Duplicate' ? 'Warning' : 'Success'}"/>
            <Text id="_IDGenTextTamNoVal" text="{resultModel>matchedMaterialNo}"/>
            <Text id="_IDGenTextTamDescVal" text="{resultModel>matchedMaterialDesc}"/>
            <Text id="_IDGenTextTamLongDescVal" text="{resultModel>matchedLongDesc}"/>
        </cells>
    </ColumnListItem>
</items>
                    </Table>

                </VBox>

            </VBox>
        </content>
    </Page>
</mvc:View>