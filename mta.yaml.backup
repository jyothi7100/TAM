_schema-version: 3.3.0
ID: tam-app
description: A simple CAP project.
version: 1.0.0
modules:
  - name: tam-app-srv
    type: nodejs
    path: gen/srv
    requires:
      - name: tam-app-db
      - name: uaa_tam-app
      - name: tam-credentials
    provides:
      - name: srv-api
        properties:
          srv-url: ${default-url}
    parameters:
      buildpack: nodejs_buildpack
      instances: 1
    build-parameters:
      builder: npm-ci
  - name: tam-app-db-deployer
    type: hdb
    path: gen/db
    requires:
      - name: tam-app-db
    parameters:
      buildpack: nodejs_buildpack
  - name: tam-app-destination-content
    type: com.sap.application.content
    requires:
      - name: tam-app-destination-service
        parameters:
          content-target: true
      - name: tam-app_html_repo_host
        parameters:
          service-key:
            name: tam-app_html_repo_host-key
      - name: uaa_tam-app
        parameters:
          service-key:
            name: uaa_tam-app-key
    parameters:
      content:
        instance:
          destinations:
            - Name: ManagedAppRouter_tam_app_html_repo_host
              ServiceInstanceName: tam-app-html5-app-host-service
              ServiceKeyName: tam-app_html_repo_host-key
              sap.cloud.service: ManagedAppRouter
            - Authentication: OAuth2UserTokenExchange
              Name: ManagedAppRouter_uaa_tam_app
              ServiceInstanceName: tam-app-xsuaa-service
              ServiceKeyName: uaa_tam-app-key
              sap.cloud.service: ManagedAppRouter
          existing_destinations_policy: ignore
    build-parameters:
      no-source: true
  - name: tam-app-app-content
    type: com.sap.application.content
    path: .
    requires:
      - name: tam-app_html_repo_host
        parameters:
          content-target: true
    build-parameters:
      build-result: resources
      requires:
        - artifacts:
            - project1.zip
          name: project1
          target-path: resources/
  - name: project1
    type: html5
    path: app/project1
    requires:
      - name: srv-api
    build-parameters:
      build-result: dist
      builder: custom
      commands:
        - npm install
        - npm run build:cf
      supported-platforms:
        []
  - name: tam-app
    type: approuter.nodejs
    path: app/router
    parameters:
      keep-existing-routes: true
      disk-quota: 256M
      memory: 256M
    requires:
      - name: srv-api
        group: destinations
        properties:
          name: srv-api
          url: ~{srv-url}
          forwardAuthToken: true
      - name: uaa_tam-app
      - name: tam-app-html5-repo-runtime
      - name: tam-app-destination-service
        group: destinations
        properties:
          name: ui5
          url: https://ui5.sap.com
          forwardAuthToken: false
    provides:
      - name: app-api
        properties:
          app-protocol: ${protocol}
          app-uri: ${default-uri}
resources:
  - name: tam-app-db
    type: com.sap.xs.hdi-container
    parameters:
      service: hana
      service-plan: hdi-shared
  - name: tam-app-destination-service
    type: org.cloudfoundry.managed-service
    parameters:
      config:
        HTML5Runtime_enabled: true
        init_data:
          instance:
            destinations:
              - Authentication: NoAuthentication
                Name: ui5
                ProxyType: Internet
                Type: HTTP
                URL: https://ui5.sap.com
            existing_destinations_policy: update
        version: 1.0.0
      service: destination
      service-name: tam-app-destination-service
      service-plan: lite
  - name: tam-app_html_repo_host
    type: org.cloudfoundry.managed-service
    parameters:
      service: html5-apps-repo
      service-name: tam-app-html5-app-host-service
      service-plan: app-host
  - name: tam-app-html5-repo-runtime
    type: org.cloudfoundry.managed-service
    parameters:
      service: html5-apps-repo
      service-plan: app-runtime
  - name: uaa_tam-app
    type: org.cloudfoundry.managed-service
    parameters:
      config:
        oauth2-configuration:
          credential-types:
            - binding-secret
            - x509
          redirect-uris:
            - https://*~{app-api/app-uri}/**
        tenant-mode: dedicated
        xsappname: tam-app-${org}-${space}
      path: ./xs-security.json
      service: xsuaa
      service-name: tam-app-xsuaa-service
      service-plan: application
    requires:
      - name: app-api
  - name: tam-credentials
    type: org.cloudfoundry.existing-service
    parameters:
      service-name: tam-credentials
parameters:
  deploy_mode: html5-repo
  enable-parallel-deployments: true
build-parameters:
  before-all:
    - builder: custom
      commands:
        - npm ci
        - npx cds build --production